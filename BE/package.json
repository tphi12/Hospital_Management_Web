{
  "name": "hospital-management-be",
  "version": "1.0.0",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "setup": "node scripts/setupDatabase.js",
    "hash": "node scripts/generateHash.js",
    "db:migrate": "node database/runMigrations.js up",
    "db:status": "node database/runMigrations.js status",
    "db:mysql-version": "node scripts/checkMySqlVersion.js",
    "db:weekly-work:backfill": "node scripts/backfillWeeklyWorkAssignments.js",
    "db:weekly-work:finalize": "node scripts/finalizeWeeklyWorkAssignments.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "test:unit": "jest tests/services",
    "test:integration": "jest tests/integration"
  },
  "keywords": [
    "hospital",
    "management",
    "api"
  ],
  "author": "",
  "license": "ISC",
  "description": "Hospital Management Backend - Document and Schedule System",
  "dependencies": {
    "@azure/storage-blob": "^12.17.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.6.5",
    "pdfkit": "^0.17.2",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "uuid": "^9.0.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
